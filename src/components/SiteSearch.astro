---
import { getCollection } from 'astro:content';

type Props = {
	class?: string;
};

const { class: className } = Astro.props;

const docs = await getCollection('docs', ({ data }) => data.draft !== true);

const stripMarkdown = (content = '') =>
	content
		.replace(/<[^>]+>/g, ' ')
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/`([^`]+)`/g, '$1')
		.replace(/!\[[^\]]*]\([^)]*\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]*\)/g, '$1')
		.replace(/[#>*_\-|:]+/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

const toUrl = (id: string) => {
	const slug = id.replace(/\/?index$/, '');
	return slug ? `/${slug}/` : '/';
};

const searchEntries = docs.map((entry) => ({
	title: entry.data.title,
	description: entry.data.description ?? '',
	url: toUrl(entry.id),
	content: stripMarkdown(entry.body ?? entry.rendered?.html ?? ''),
}));
---

<site-search class={className} data-entries={JSON.stringify(searchEntries)}>
	<button type="button" class="search-button" aria-label="Search" data-open-search>
		<svg aria-hidden="true" viewBox="0 0 24 24" class="search-icon">
			<path
				d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
				fill="none"
				stroke="currentColor"
				stroke-linecap="round"
				stroke-linejoin="round"
				stroke-width="2"
			/>
		</svg>
		<span class="search-label">Search</span>
		<span class="search-shortcut" aria-hidden="true"><kbd>Ctrl</kbd><kbd>K</kbd></span>
	</button>

	<dialog aria-label="Search" data-search-dialog>
		<div class="search-panel">
			<form class="search-form" data-search-form>
				<svg aria-hidden="true" viewBox="0 0 24 24" class="search-icon">
					<path
						d="m21 21-4.3-4.3m1.3-5.2a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
						fill="none"
						stroke="currentColor"
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
					/>
				</svg>
				<input
				type="search"
				placeholder="Search"
				autocomplete="off"
				spellcheck="false"
					data-search-input
				/>
				<button type="button" class="cancel-button" data-close-search>取消</button>
			</form>
			<div class="search-results" data-search-results>
				<p class="search-empty">输入关键词开始搜索</p>
			</div>
		</div>
	</dialog>
</site-search>

<script>
	class SiteSearch extends HTMLElement {
		connectedCallback() {
			const entries = JSON.parse(this.dataset.entries || '[]');
			const openButton = this.querySelector('[data-open-search]');
			const dialog = this.querySelector('[data-search-dialog]');
			const closeButton = this.querySelector('[data-close-search]');
			const form = this.querySelector('[data-search-form]');
			const input = this.querySelector('[data-search-input]');
			const results = this.querySelector('[data-search-results]');

			if (!(dialog instanceof HTMLDialogElement) || !(input instanceof HTMLInputElement) || !results) {
				return;
			}

			const normalize = (value) => value.toLowerCase().normalize('NFKC').trim();
			const clearResults = (message) => {
				results.replaceChildren(Object.assign(document.createElement('p'), {
					className: 'search-empty',
					textContent: message,
				}));
			};
			const makeSnippet = (entry, query) => {
				const source = entry.content || entry.description || '';
				const normalizedSource = normalize(source);
				const normalizedQuery = normalize(query);
				const index = normalizedSource.indexOf(normalizedQuery);
				if (index === -1) return source.slice(0, 140);
				const start = Math.max(0, index - 50);
				const end = Math.min(source.length, index + normalizedQuery.length + 90);
				return `${start > 0 ? '...' : ''}${source.slice(start, end)}${end < source.length ? '...' : ''}`;
			};
			const search = (query) => {
				const normalizedQuery = normalize(query);
				if (!normalizedQuery) {
					clearResults('输入关键词开始搜索');
					return;
				}
				const terms = normalizedQuery.split(/\s+/).filter(Boolean);
				const matches = entries
					.map((entry) => {
						const title = normalize(entry.title);
						const description = normalize(entry.description);
						const content = normalize(entry.content);
						const haystack = `${title} ${description} ${content}`;
						if (!terms.every((term) => haystack.includes(term))) return null;

						let score = 0;
						for (const term of terms) {
							if (title.includes(term)) score += 60;
							if (description.includes(term)) score += 25;
							if (content.includes(term)) score += 10;
						}
						if (title.includes(normalizedQuery)) score += 80;
						return { ...entry, score };
					})
					.filter(Boolean)
					.sort((a, b) => b.score - a.score)
					.slice(0, 10);

				if (!matches.length) {
					clearResults('没有找到匹配内容');
					return;
				}

				results.replaceChildren(
					...matches.map((entry) => {
						const link = document.createElement('a');
						link.className = 'search-result';
						link.href = entry.url;

						const meta = document.createElement('small');
						meta.textContent = entry.url.replace(/^\/|\/$/g, '').replaceAll('/', ' / ') || '首页';

						const title = document.createElement('strong');
						title.textContent = entry.title;

						const excerpt = document.createElement('span');
						excerpt.textContent = makeSnippet(entry, normalizedQuery);

						link.append(meta, title, excerpt);
						return link;
					}),
				);
			};
			const open = () => {
				dialog.showModal();
				search(input.value);
				requestAnimationFrame(() => input.focus());
				document.body.toggleAttribute('data-search-modal-open', true);
			};
			const close = () => {
				dialog.close();
				document.body.toggleAttribute('data-search-modal-open', false);
			};

			openButton?.addEventListener('click', open);
			closeButton?.addEventListener('click', close);
			form?.addEventListener('submit', (event) => event.preventDefault());
			input.addEventListener('input', () => search(input.value));
			dialog.addEventListener('close', () => document.body.toggleAttribute('data-search-modal-open', false));
			document.addEventListener('keydown', (event) => {
				if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
					event.preventDefault();
					open();
				}
			});
		}
	}

	customElements.define('site-search', SiteSearch);
</script>

<style>
	site-search {
		display: contents;
	}

	.search-button {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		width: 100%;
		max-width: 22rem;
		height: 3rem;
		padding: 0 0.875rem;
		color: var(--sl-color-gray-2);
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		box-shadow: var(--sl-shadow-sm);
		cursor: pointer;
		font: inherit;
		text-align: start;
	}

	.search-button:hover {
		color: var(--sl-color-white);
		border-color: var(--sl-color-gray-4);
	}

	.search-icon {
		width: 1.25rem;
		height: 1.25rem;
		flex: none;
	}

	.search-label {
		flex: 1;
		min-width: 0;
	}

	.search-shortcut {
		display: none;
		gap: 0.125rem;
	}

	kbd {
		padding: 0.125rem 0.375rem;
		color: var(--sl-color-gray-2);
		background: var(--sl-color-gray-6);
		border-radius: 0.25rem;
		font-size: var(--sl-text-sm);
	}

	dialog {
		position: fixed;
		inset: 0;
		width: min(42rem, calc(100vw - 2rem));
		max-height: min(34rem, calc(100vh - 5rem));
		margin: auto;
		padding: 0;
		color: var(--sl-color-white);
		background: var(--sl-color-bg);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.75rem;
		outline: none;
		box-shadow: var(--sl-shadow-lg);
		overflow: hidden;
		transform: translateY(-8vh);
	}

	dialog::backdrop {
		background: rgb(15 18 25 / 0.56);
		backdrop-filter: blur(2px);
	}

	.search-panel {
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		max-height: inherit;
	}

	.search-form {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 1rem;
		border-bottom: 1px solid var(--sl-color-gray-6);
	}

	.search-form input {
		flex: 1;
		min-width: 0;
		color: var(--sl-color-white);
		background: transparent;
		border: 0;
		outline: 0;
		font: inherit;
		font-size: var(--sl-text-lg);
	}

	.search-form input::-webkit-search-cancel-button {
		display: none;
	}

	.cancel-button {
		padding: 0.375rem 0.625rem;
		color: var(--sl-color-gray-2);
		background: transparent;
		border: 0;
		border-radius: 0.25rem;
		cursor: pointer;
		font: inherit;
	}

	.cancel-button:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}

	.search-results {
		overflow: auto;
		padding: 0.75rem;
		background: var(--sl-color-bg-nav);
	}

	.search-empty {
		margin: 2rem 0;
		color: var(--sl-color-gray-3);
		text-align: center;
	}

	:global(body[data-search-modal-open]) {
		overflow: hidden;
	}

	:global(site-search .search-empty) {
		margin: 2rem 0;
		color: var(--sl-color-gray-3);
		text-align: center;
	}

	:global(site-search .search-result) {
		display: grid;
		gap: 0.35rem;
		padding: 0.875rem 1rem;
		color: var(--sl-color-white);
		text-decoration: none;
		border: 1px solid transparent;
		border-radius: 0.5rem;
		background: transparent;
	}

	:global(site-search .search-result + .search-result) {
		margin-top: 0.375rem;
	}

	:global(site-search .search-result:hover),
	:global(site-search .search-result:focus-visible) {
		background: var(--sl-color-bg);
		border-color: var(--sl-color-gray-5);
		outline: none;
	}

	:global(site-search .search-result small) {
		color: var(--sl-color-accent-high);
		font-size: var(--sl-text-xs);
		font-weight: 600;
		line-height: 1.3;
	}

	:global(site-search .search-result strong) {
		color: var(--sl-color-white);
		font-size: var(--sl-text-base);
		line-height: 1.35;
	}

	:global(site-search .search-result span) {
		display: -webkit-box;
		overflow: hidden;
		color: var(--sl-color-gray-2);
		font-size: var(--sl-text-sm);
		line-height: 1.6;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	@media (min-width: 50rem) {
		.search-shortcut {
			display: flex;
		}
	}
</style>
